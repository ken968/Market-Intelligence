# ============================================================
# DATA FILES — NEVER TRACK THESE IN GIT
# These are live data warehouses generated by sync scripts.
# Tracking them in Git causes data to roll back to old dates
# whenever a git operation is performed (the core bug).
# ============================================================
data/*.csv
data/*.json
data/alternative/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

